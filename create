class LaunchProgressScreen(Screen):
    """Screen showing live pod launch progress with events."""

    BINDINGS = [("q", "cancel", "Cancel")]

    def __init__(self, namespace: str, pod_name: str, command: str, manifest: str, temp_path: str):
        self.namespace = namespace
        self.pod_name = pod_name
        self.command = command
        self.manifest = manifest
        self.temp_path = temp_path
        self.cancelled = False
        super().__init__()

    def compose(self) -> ComposeResult:
        yield Header(show_clock=True)
        yield Container(
            Label(f"Launching {self.pod_name}", classes="title"),
            Static("Initializing...", id="status-line"),
            Static("", id="pod-status"),
            Label("Recent Events:"),
            Static("Waiting for events...", id="events-log"),
            Horizontal(
                Button("Cancel", variant="error", id="cancel-btn"),
                id="button-row"
            ),
            id="progress-container"
        )
        yield Footer()

    def on_mount(self):
        # Gray out the container while working
        container = self.query_one("#progress-container", Container)
        container.styles.opacity = 0.7
        self.run_worker(self._launch_worker())

    async def _launch_worker(self):
        """Background worker that handles the launch process."""
        import time

        # Check if pod already exists
        self._update_status("Checking if pod exists...")
        rc, stdout, _ = run_kubectl(["get", "pod", self.pod_name, "-n", self.namespace, "-o", "json"])
        pod_exists = rc == 0

        if pod_exists:
            try:
                pod_data = json.loads(stdout)
                phase = pod_data.get("status", {}).get("phase", "Unknown")
                if phase == "Running":
                    self._update_status("✓ Pod already running")
                    self._exec_into_pod()
                    return
                elif phase in ["Pending", "ContainerCreating"]:
                    self._update_status(f"Pod exists and is {phase}")
                else:
                    self._update_status(f"Pod in {phase} state, deleting...")
                    run_kubectl(["delete", "pod", self.pod_name, "-n", self.namespace])
                    pod_exists = False
                    await self._sleep(2)
            except json.JSONDecodeError:
                pass

        # Create pod if needed
        if not pod_exists:
            self._update_status("Creating pod...")
            rc, _, stderr = run_kubectl(["apply", "-f", self.temp_path])
            if rc != 0:
                self._update_status(f"Failed: {stderr}", error=True)
                self._cleanup()
                return
            self._update_status("✓ Pod created")

        # Wait for pod to be ready with live updates
        start_time = time.time()
        timeout = 360  # 6 minutes
        check_interval = 2

        while time.time() - start_time < timeout and not self.cancelled:
            # Get pod status
            rc, stdout, _ = run_kubectl(["get", "pod", self.pod_name, "-n", self.namespace, "-o", "json"])
            pod_status = "Unknown"
            ready_status = "False"
            waiting_reason = ""

            if rc == 0:
                try:
                    pod_data = json.loads(stdout)
                    phase = pod_data.get("status", {}).get("phase", "Unknown")
                    conditions = pod_data.get("status", {}).get("conditions", [])
                    ready_condition = next((c for c in conditions if c.get("type") == "Ready"), None)
                    ready_status = ready_condition.get("status", "False") if ready_condition else "False"

                    container_statuses = pod_data.get("status", {}).get("containerStatuses", [])
                    for cs in container_statuses:
                        waiting = cs.get("state", {}).get("waiting", {})
                        if waiting:
                            waiting_reason = waiting.get("reason", "")
                            break

                    pod_status = phase

                    if phase == "Running" and ready_status == "True":
                        self._update_status("✓ Pod is ready!")
                        self._exec_into_pod()
                        return
                    elif phase == "Failed":
                        self._update_status("Pod failed to start", error=True)
                        self._cleanup()
                        return

                except json.JSONDecodeError:
                    pass

            # Update display
            elapsed = int(time.time() - start_time)
            status_text = f"[{elapsed}s] Pod: {pod_status}"
            if ready_status == "True":
                status_text += " (Ready)"
            if waiting_reason:
                status_text += f" - {waiting_reason}"
            self._update_status(status_text)
            self._update_pod_display(pod_status, ready_status)

            # Get recent events
            self._update_events()

            await self._sleep(check_interval)

        # Timeout
        if not self.cancelled:
            self._update_status("Timeout: Pod did not become ready in 6min", error=True)
        self._cleanup()

    def _update_status(self, text: str, error: bool = False):
        status = self.query_one("#status-line", Static)
        status.update(text)
        if error:
            status.styles.color = "red"

    def _update_pod_display(self, phase: str, ready: str):
        pod_status = self.query_one("#pod-status", Static)
        pod_status.update(f"Status: {phase} | Ready: {ready}")

    def _update_events(self):
        """Get the 2 most recent events for the pod."""
        # Get events from kubectl describe
        rc, stdout, _ = run_kubectl(["get", "events", "-n", self.namespace,
                                   "--field-selector", f"involvedObject.name={self.pod_name}",
                                   "--sort-by=.lastTimestamp", "-o", "json"])
        if rc != 0:
            return

        try:
            data = json.loads(stdout)
            items = data.get("items", [])
            # Get last 2 events
            recent = items[-2:] if len(items) >= 2 else items

            lines = []
            for evt in recent:
                reason = evt.get("reason", "")
                msg = evt.get("message", "")
                last_seen = evt.get("lastTimestamp", "")
                if reason and msg:
                    lines.append(f"  {reason}: {msg}")
                elif msg:
                    lines.append(f"  {msg}")

            if lines:
                events_log = self.query_one("#events-log", Static)
                events_log.update("\n".join(lines))
        except (json.JSONDecodeError, KeyError):
            pass

    def _exec_into_pod(self):
        """Exec into the running pod."""
        self._cleanup()
        # Save exec command and exit - main() will handle the exec
        cmd = ["kubectl"]
        if KUBE_CONTEXT:
            cmd.extend(["--context", KUBE_CONTEXT])
        cmd.extend(["exec", "-n", self.namespace, "-it", self.pod_name, "--", self.command])
        NewApp._exec_command = cmd
        self.app.exit()

    def _cleanup(self):
        """Cleanup temp files and restore UI."""
        try:
            os.unlink(self.temp_path)
        except:
            pass
        # Restore opacity
        try:
            container = self.query_one("#progress-container", Container)
            container.styles.opacity = 1.0
        except:
            pass

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "cancel-btn":
            self.cancel()

    def cancel(self):
        self.cancelled = True
        self._update_status("Cancelled by user")
        self._cleanup()
        self.app.pop_screen()

    async def _sleep(self, seconds: float):
        import asyncio
        await asyncio.sleep(seconds)


class ConfirmScreen(Screen):
    """Simple confirmation dialog."""

    BINDINGS = [("y", "yes", "Yes"), ("n", "no", "No"), ("enter", "yes", "Yes")]

    def __init__(self, message: str):
        self.message = message
        super().__init__()

    def compose(self) -> ComposeResult:
        yield Container(
            Label(self.message, classes="title"),
            Horizontal(
                Button("Yes", variant="success", id="yes-btn"),
                Button("No", variant="error", id="no-btn"),
            ),
            id="confirm-dialog"
        )

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "yes-btn":
            self.dismiss(True)
        else:
            self.dismiss(False)

    def action_yes(self):
        self.dismiss(True)

    def action_no(self):
        self.dismiss(False)


class NewApp(App):
    """Main TUI application."""

    TITLE = "Hydra Dashboard"
    _exec_command: list[str] | None = None

    def __init__(self, namespace=None):
        super().__init__()
        self.initial_namespace = namespace

    CSS = """
    Screen { align: center middle; }
    .title { text-align: center; text-style: bold; color: $primary; margin: 1 0; }
    Container {
        border: solid $primary;
