        if not pod_name:
            pod_name = f"interactive-{datetime.datetime.now().strftime('%Y%m%d-%H%M%S')}"

        # Build tolerations if GPU is requested (only for non-none tiers)
        gpu_request = "0"
        tolerations = ""
        if nodetier != "none":
            # Look up GPU from tier
            for tier in self.nodetiers:
                if tier[1] == nodetier:
                    gpu_request = tier[2].get('gpu_request', '0')
                    break
            if gpu_request and gpu_request != '0':
                tolerations = """  tolerations:
  - key: nvidia.com/gpu
    operator: Exists
    effect: NoSchedule
"""

        # Create pod manifest with conservative resources (512Mi RAM, 1 CPU limit)
        node_selector = f"""  nodeSelector:
