    #pvc-label { margin: 1 0; }
    .hint { text-style: dim; margin: 0; }
    #image-suggest { margin-top: 0; }
    Spacer { height: 1; }
    #pvc-select-container Checkbox { width: 100%; }
    """

    def __init__(self, namespace: Optional[str] = None):
        self.initial_namespace = namespace
        super().__init__()

    def on_mount(self):
        # Load saved config
        config = load_dotfile()

        # Check if context is set via env var
        env_ctx = os.environ.get("KUBE_CONTEXT", "")
        if env_ctx:
            set_context(env_ctx)

        # Restore saved context if no env override and saved exists
        saved_ctx = config.get("context")
        if not KUBE_CONTEXT and saved_ctx is not None:
            set_context(saved_ctx)

        # Check if we need to prompt for context (first boot, no env, no saved)
        need_context_prompt = not KUBE_CONTEXT and saved_ctx is None

        # Determine namespace
        ns = self.initial_namespace or config.get("namespace")
        need_namespace_prompt = not ns

        if need_context_prompt:
            # First boot - ask for context first
            def on_context_select(selected_ctx: str | None):
                if selected_ctx is not None:
                    set_context(selected_ctx)
                    # Now check if we need namespace
                    if need_namespace_prompt:
                        self._prompt_for_namespace(config)
                    else:
                        self.push_screen(MainMenuScreen(ns))
                else:
                    # User cancelled context selection - exit
                    self.exit()

            self.push_screen(ContextScreen(), callback=on_context_select)
        elif need_namespace_prompt:
            # Have context but need namespace
            self._prompt_for_namespace(config)
        else:
            # Have both - go to main menu
            self.push_screen(MainMenuScreen(ns))

    def _prompt_for_namespace(self, config: dict):
        """Prompt user to select namespace."""
        def on_namespace_select(selected_ns: str | None):
            if selected_ns:
                save_dotfile({"namespace": selected_ns, "context": KUBE_CONTEXT})
                self.push_screen(MainMenuScreen(selected_ns))
            else:
                self.exit()

        self.push_screen(NamespaceScreen(), callback=on_namespace_select)


def main():
    parser = argparse.ArgumentParser(
        description="Interactive TUI for creating Kubernetes resources",
        epilog="Environment: KUBE_CONTEXT - Override kubectl context (default: current context)"
    )
    parser.add_argument("--namespace", "-n", help="Override the saved namespace")
    parser.add_argument("--context", "-c", help="Override the kubectl context")
    parser.add_argument("--version", "-v", action="version", version="%(prog)s 1.0")
    args = parser.parse_args()

    # Apply CLI context override
    if args.context:
        set_context(args.context)

    app = NewApp(namespace=args.namespace)
    app.run()

    # Check if we need to exec into a pod after exit
    if NewApp._exec_command:
        # Small delay to let terminal settle after Textual exits
        time.sleep(0.1)
        # Run kubectl exec
        print(f"\n[hydra] Connecting to pod...\n")
        result = subprocess.run(NewApp._exec_command)

        # After exec exits, prompt for pod cleanup
        pod_name = None
        namespace = None
        for i, arg in enumerate(NewApp._exec_command):
            if arg == "-n" or arg == "--namespace":
                namespace = NewApp._exec_command[i + 1] if i + 1 < len(NewApp._exec_command) else None
            if arg.startswith("-n") and len(arg) > 2:
                namespace = arg[2:]

        # Extract pod name from exec command: kubectl exec ... pod_name -- command
        try:
            # Find the pod name (after -n/-it flags, before --)
            dash_dash_idx = NewApp._exec_command.index("--")
            pod_name = NewApp._exec_command[dash_dash_idx - 1]
        except (ValueError, IndexError):
            pass

        if pod_name and namespace:
            # Check if pod still exists
            rc, _, _ = run_kubectl(["get", "pod", pod_name, "-n", namespace])
            if rc == 0:
                print(f"\n[hydra] Interactive session ended.")
                print(f"[hydra] Pod '{pod_name}' is still running.")
                print(f"\nOptions:")
                print(f"  k) Kill pod (default - press Enter)")
                print(f"  d) Detach (leave pod running)")
                print(f"  r) Re-attach")
                try:
                    choice = input("\nChoice [k]: ").strip().lower()
                    if choice in ("", "k"):
                        print(f"[hydra] Killing pod {pod_name}...")
                        rc, _, stderr = run_kubectl(["delete", "pod", pod_name, "-n", namespace])
                        if rc == 0:
                            print(f"[hydra] Pod killed.")
                        else:
                            print(f"[hydra] Failed to kill pod: {stderr}")
                    elif choice == "r":
                        print(f"[hydra] Re-attaching...")
                        subprocess.run(NewApp._exec_command)
                    else:
                        print(f"[hydra] Pod left running. Re-attach with:")
                        ctx_flag = f" --context {KUBE_CONTEXT}" if KUBE_CONTEXT else ""
                        print(f"  kubectl{ctx_flag} exec -n {namespace} -it {pod_name} -- /bin/bash")
                except (EOFError, KeyboardInterrupt):
                    # Ungraceful exit - default to kill
                    print(f"\n[hydra] Interrupted. Killing pod {pod_name}...")
                    run_kubectl(["delete", "pod", pod_name, "-n", namespace])
                    print(f"[hydra] Pod killed.")


if __name__ == "__main__":
    main()
