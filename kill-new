#!/usr/bin/env bash
set -Eeuo pipefail

# =============================================================================
# kill-new: Clean job cleanup script for launch-new resources
# =============================================================================

readonly NS="${NAMESPACE:-robot-learning}"
readonly DIVISIONS=(robot-learning humanoid)
readonly LABEL_SELECTOR="ethrobotics.ch/managed-by=launch"

# All resource kinds launch-new can produce. Order matters for delete (controllers
# before owned objects), but with --ignore-not-found duplicates are harmless.
# InferenceService is only present on clusters with KServe installed; the
# delete commands swallow the "no resources" / unknown-kind errors.
readonly KINDS=(trainjob job deployment inferenceservice service)

# =============================================================================
# Helpers
# =============================================================================

log() { echo "[kill-new] $*" >&2; }
die() { log "$*"; exit 1; }

usage() {
  cat >&2 <<'EOF'
Usage: ./kill-new <target>

  mine         Delete your jobs (by launcher hash)
  <job-name>   Delete specific job (e.g., launch-new-20260418-120000)
  <namespace>  Delete all launch-new jobs in division namespace

Examples:
  ./kill-new mine
  ./kill-new launch-new-20260418-120000
  ./kill-new robot-learning
EOF
}

get_launcher_id() {
  if [[ -n "${LAUNCHER_ID:-}" ]]; then
    echo "$LAUNCHER_ID"
  elif command -v aws &>/dev/null && aws_arn=$(aws sts get-caller-identity --query Arn --output text 2>/dev/null); then
    echo "aws:$aws_arn"
  else
    echo "local:${USER:-unknown}@$(hostname -s)"
  fi
}

launcher_hash() {
  echo -n "$1" | shasum -a 256 | cut -c1-16
}

valid_job_name() {
  [[ "$1" =~ ^launch-new-[0-9]{8}-[0-9]{6}$ ]]
}

valid_ns() {
  [[ "$1" =~ ^[a-z0-9]([-a-z0-9]*[a-z0-9])?$ ]]
}

is_division() {
  local d
  for d in "${DIVISIONS[@]}"; do [[ "$1" == "$d" ]] && return 0; done
  return 1
}

ns_exists() {
  kubectl get namespace "$1" &>/dev/null
}

# =============================================================================
# List Jobs
# =============================================================================

list_jobs() {
  local ns found=0
  for ns in "${DIVISIONS[@]}"; do
    ns_exists "$ns" || continue

    local kind rows
    for kind in "${KINDS[@]}"; do
      rows=$(kubectl -n "$ns" get "$kind" -l "$LABEL_SELECTOR" --no-headers 2>/dev/null || true)
      if [[ -n "$rows" ]]; then
        found=1
        printf '  %s %ss:\n' "$ns" "$kind"
        echo "$rows" | awk '{print "    " $1}'
      fi
    done
  done

  [[ "$found" == 0 ]] && echo "  No launch-new jobs found."
}

# =============================================================================
# Delete Operations
# =============================================================================

delete_one() {
  local name="$1"
  log "Deleting $name in $NS..."

  # Delete by exact name across every kind launch-new might create.
  # Stderr is suppressed because some clusters lack KServe (unknown kind
  # "InferenceService"), which is fine.
  local kind
  for kind in "${KINDS[@]}"; do
    kubectl -n "$NS" delete --ignore-not-found "$kind" "$name" 2>/dev/null || true
  done

  # Delete any extra resources owned by this job by label (e.g. additional
  # Services that weren't named exactly $JOB_NAME).
  for kind in "${KINDS[@]}"; do
    kubectl -n "$NS" delete --ignore-not-found "$kind" \
      -l "${LABEL_SELECTOR},ethrobotics.ch/job-name=${name}" 2>/dev/null || true
  done

  kubectl -n "$NS" delete --ignore-not-found configmap "${name}-files" 2>/dev/null || true
}

delete_mine() {
  local lid=$(get_launcher_id)
  local hash=$(launcher_hash "$lid")
  local sel="${LABEL_SELECTOR},ethrobotics.ch/launcher-hash=${hash}"

  local found=0
  local kind names
  for kind in "${KINDS[@]}"; do
    names=$(kubectl -n "$NS" get "$kind" -l "$sel" -o name 2>/dev/null || true)
    [[ -n "$names" ]] && found=1
  done
  local cmaps=$(kubectl -n "$NS" get configmap -l "$sel" -o name 2>/dev/null || true)
  [[ -n "$cmaps" ]] && found=1

  if [[ "$found" == 0 ]]; then
    log "No jobs found for: $lid ($hash)"
    return
  fi

  log "Deleting jobs for: $lid ($hash)"
  for kind in "${KINDS[@]}"; do
    names=$(kubectl -n "$NS" get "$kind" -l "$sel" -o name 2>/dev/null || true)
    if [[ -n "$names" ]]; then
      echo "$names" | sed 's/^/  /'
      kubectl -n "$NS" delete --ignore-not-found "$kind" -l "$sel" 2>/dev/null || true
    fi
  done
  [[ -n "$cmaps" ]] && kubectl -n "$NS" delete --ignore-not-found configmap -l "$sel"
}

delete_all() {
  local ns="$1"
  log "WARNING: About to delete ALL launch-new jobs in $ns"
  read -rp "Continue? [y/N] " reply
  [[ "$reply" =~ ^[Yy] ]] || { log "Aborted."; exit 1; }

  log "Deleting all launch-new resources in $ns..."
  local kind
  for kind in "${KINDS[@]}"; do
    kubectl -n "$ns" delete --ignore-not-found "$kind" -l "$LABEL_SELECTOR" 2>/dev/null || true
  done
  kubectl -n "$ns" delete --ignore-not-found configmap -l "$LABEL_SELECTOR"
}

# =============================================================================
# Main
# =============================================================================

main() {
  [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
  [[ $# -eq 1 ]] || { usage; exit 1; }

  local target="$1"

  if [[ "$target" == "mine" ]]; then
    delete_mine
  elif valid_job_name "$target"; then
    delete_one "$target"
  elif valid_ns "$target" && is_division "$target" && ns_exists "$target"; then
    delete_all "$target"
  else
    die "Unknown target: $target"
  fi
}

main "$@"
