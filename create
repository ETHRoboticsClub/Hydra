    def _generate_preview(self) -> str:
        folder_path = Path(self.folder).expanduser().resolve()
        lines = [
            f"Folder: {folder_path}",
            f"Files:",
            f"  - deploy.yaml ({self.resource_type} manifest)",
            f"  - entrypoint.sh",
        ]
        if self.init_script:
            lines.append("  - init.sh")
        lines.extend([
            "",
            f"Configuration:",
            f"  Namespace: {self.namespace}",
            f"  Image: {self.image}",
            f"  Profile: {self.profile}",
            f"  Node Tier: {self.nodetier}",
            f"  Resources:",
            f"    CPU: {self.nodetier_resources.get('cpu_request', '?')}/{self.nodetier_resources.get('cpu_limit', '?')}",
            f"    Memory: {self.nodetier_resources.get('mem_request', '?')}/{self.nodetier_resources.get('mem_limit', '?')}",
            f"    GPU: {self.nodetier_resources.get('gpu_request', '?')}/{self.nodetier_resources.get('gpu_limit', '?')}",
            f"  PVCs: {', '.join(self.pvcs) if self.pvcs else 'None'}",
            f"  Init script: {'Yes' if self.init_script else 'No'}",
        ])
        return "\n".join(lines)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "back-btn":
            self.app.pop_screen()
        elif event.button.id == "apply-btn":
            self.create_and_apply()

    def create_and_apply(self):
        folder_path = Path(self.folder).expanduser().resolve()
        folder_path.mkdir(parents=True, exist_ok=True)

        try:
            # Write entrypoint.sh
            entrypoint_path = folder_path / "entrypoint.sh"
            with open(entrypoint_path, "w") as f:
                f.write(self.entrypoint)
            os.chmod(entrypoint_path, 0o755)

            # Write init.sh if provided
            has_init = bool(self.init_script)
            if has_init:
                init_path = folder_path / "init.sh"
                with open(init_path, "w") as f:
                    f.write(self.init_script)
                os.chmod(init_path, 0o755)

            # Generate deploy.yaml using template
            template_file = TEMPLATES_DIR / f"{self.resource_type.lower()}.yaml"
            if not template_file.exists():
                self.notify(f"Template not found: {template_file}", severity="error")
                return

            with open(template_file) as f:
                template_content = f.read()

            # Substitute variables
            manifest = self._substitute_template(template_content, has_init)

            deploy_path = folder_path / "deploy.yaml"
            with open(deploy_path, "w") as f:
                f.write(manifest)

            self.notify(f"Files created in {folder_path}")

            # Run launch-new to apply
            self.notify(f"Running: ./launch-new {self.profile} {folder_path}")

            def apply_callback(confirmed: bool):
                if confirmed:
                    env = os.environ.copy()
                    if KUBE_CONTEXT:
                        env["KUBE_CONTEXT"] = KUBE_CONTEXT
                    result = subprocess.run(
                        ["./launch-new", self.profile, str(folder_path)],
                        cwd=SCRIPT_DIR,
                        capture_output=True,
                        text=True,
                        env=env
                    )
                    if result.returncode == 0:
                        self.notify("Deployment applied successfully!")
                        self.app.pop_screen()
                        self.app.pop_screen()  # Go back to main menu
                    else:
                        self.notify(f"launch-new failed: {result.stderr}", severity="error")
                else:
                    self.notify("Deployment cancelled - files saved for manual application")
                    self.app.pop_screen()
                    self.app.pop_screen()

            self.app.push_screen(
                ConfirmScreen(f"Execute ./launch-new {self.profile} {folder_path}?"),
                callback=apply_callback
            )

        except IOError as e:
            self.notify(f"Failed to create files: {e}", severity="error")

    def _substitute_template(self, template: str, has_init: bool) -> str:
        """Substitute variables in the template."""
        import datetime

        job_name = f"new-{datetime.datetime.now().strftime('%Y%m%d-%H%M%S')}"

        # Get profile values (for nodepool)
        profile_path = PROFILES_DIR / f"{self.profile}.yaml"
        nodepool = yaml_value(profile_path, "nodepool") or "default"
        shm_size = yaml_value(profile_path, "shared_memory_size") or "256Mi"

        # Use nodetier resources (selected by user)
        resources = self.nodetier_resources

        # Get launcher info
        user = os.environ.get("USER", "unknown")
        launcher_id = f"local:{user}@{os.uname().nodename}"
        launcher_hash = self._hash_launcher(launcher_id)

        # Build init script content (escaped for YAML)
        if has_init:
            init_content = self.init_script
            init_escaped = "\n".join("                " + line for line in init_content.splitlines())
        else:
            init_escaped = ""

        # Substitute
        result = template
        replacements = {
            "JOB_NAME": job_name,
            "NAMESPACE": self.namespace,
            "PROFILE": self.profile,
            "LAUNCHER_ID": launcher_id,
            "LAUNCHER_HASH": launcher_hash,
            "USER": user,
            "SERVICE_ACCOUNT": self.defaults.get("service_account_name", "default"),
            "IMAGE": self.image,
            "INIT_IMAGE": self.image,
            "NODEPOOL": nodepool,
            "NODETIER": self.nodetier,
            "CPU_REQUEST": resources.get("cpu_request", "1"),
            "CPU_LIMIT": resources.get("cpu_limit", "4"),
            "MEM_REQUEST": resources.get("mem_request", "4Gi"),
            "MEM_LIMIT": resources.get("mem_limit", "16Gi"),
            "GPU_REQUEST": resources.get("gpu_request", "0"),
            "GPU_LIMIT": resources.get("gpu_limit", "0"),
            "DATA_PVC": self.pvcs[0] if self.pvcs else self.defaults.get("data_pvc", "data"),
            "CHECKPOINT_PVC": self.defaults.get("checkpoint_pvc", "checkpoints"),
            "S3_PVC": self.defaults.get("s3_data_pvc", "s3-data"),
            "SHM_SIZE": shm_size,
            "REPLICAS": "1",
            "CONFIGMAP_NAME": f"{job_name}-files",
            "INIT_SCRIPT": init_escaped,
            "NODEPOOL": profile_values["NODEPOOL"],
            "NODETIER": profile_values["NODETIER"],
        }

        for key, value in replacements.items():
            result = result.replace(f"{{{{{key}}}}}", str(value))

        # Remove initContainers section if no init script
        if not has_init:
            # Simple removal of initContainers section
            lines = result.splitlines()
            filtered_lines = []
            skip = False
            indent_level = None
            for line in lines:
                if "initContainers:" in line and not has_init:
                    skip = True
                    indent_level = len(line) - len(line.lstrip())
                    continue
                if skip:
                    current_indent = len(line) - len(line.lstrip())
                    if line.strip() and current_indent <= indent_level:
                        skip = False
                    else:
                        continue
                filtered_lines.append(line)
            result = "\n".join(filtered_lines)

        return result

    def _hash_launcher(self, launcher_id: str) -> str:
        import hashlib
        return hashlib.sha256(launcher_id.encode()).hexdigest()[:16]


